# Backend URL used by Vite dev proxy (only affects dev server)
VITE_BACKEND_URL=http://localhost:5000

# API base URL for the frontend (leave empty in dev to use "/api" with proxy)
# Set this in production to the full backend URL
VITE_API_BASE_URL=http://localhost:5000/api

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
