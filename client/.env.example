# Backend URL used by Vite dev proxy (only affects dev server)
VITE_BACKEND_URL=http://localhost:5000

# API base URL for the frontend
# Dev: leave empty to use "/api" with Vite proxy
# Prod: set to your deployed backend URL (e.g. https://your-api.vercel.app/api)
VITE_API_BASE_URL=http://localhost:5000/api

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
