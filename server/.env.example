PORT=5000
MONGO_URI=mongodb://localhost:27017/issasp
JWT_SECRET=change_this_to_a_long_random_secret_key_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# Supabase Auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional bootstrap admin (for deployed environments)
BOOTSTRAP_ADMIN_EMAIL=admin@university.edu
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_FORCE_RESET=false

# Email (optional — comment out if not using)
EMAIL_HOST=smtp.gmail.com
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
